# ═══════════════════════════════════════════════════════════════
#  TurfMasterPro — Root .gitignore
# ═══════════════════════════════════════════════════════════════

# ── OS Generated Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Frontend (Node / Vite / React) ─────────────────────────
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Backend (Java / Maven / Spring Boot) ────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# Spring Boot / STS
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/

# IntelliJ IDEA
*.iws
*.iml
*.ipr
out/

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
